#!/bin/sh
echo "🔍 Running pre-commit checks..."

# Capture originally staged files BEFORE any modifications
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# TS gate — prevents commits that break tsc (resilience plan track 1)
echo "🔎 Running typecheck..."
if ! pnpm run typecheck; then
  echo "❌ TypeScript errors — fix before committing (or `--no-verify` to bypass)."
  exit 1
fi

# Auto-fix linting and formatting issues
echo "📋 Running ESLint auto-fix..."
if ! pnpm run lint:fix; then
  echo "❌ ESLint found errors that could not be auto-fixed."
  echo "💡 Please fix the errors manually before committing."
  exit 1
fi

echo "✨ Auto-formatting code..."
pnpm run format

echo "✅ Linting and formatting complete!"

# Always bump version on every commit
echo "📦 Bumping version..."

# Read current version from package.json
current_version=$(node -p "require('./package.json').version")
major=$(echo "${current_version}" | cut -d. -f1)
minor=$(echo "${current_version}" | cut -d. -f2)
patch=$(echo "${current_version}" | cut -d. -f3)

# Rollover at .20 to keep patch numbers manageable
if [ "${patch}" -eq 20 ]; then
  new_minor=$((minor + 1))
  new_version="${major}.${new_minor}.0"
  echo "🚀 Rolling over to minor version"
else
  new_patch=$((patch + 1))
  new_version="${major}.${minor}.${new_patch}"
  echo "📈 Incrementing patch version"
fi

# Update package.json with new version
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
pkg.version = '${new_version}';
fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
"

echo "✅ Version bumped: ${current_version} → ${new_version}"

# Update lock file
pnpm install --lockfile-only

# Stage the version changes
git add package.json pnpm-lock.yaml

# Re-stage only the files that were originally staged (after lint/format may have modified them)
# This avoids accidentally staging unrelated working directory changes
if [ -n "${STAGED_FILES}" ]; then
  echo "${STAGED_FILES}" | xargs -r git add
fi

echo "✅ All pre-commit checks passed!"
